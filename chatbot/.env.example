# Chat provider for chatbot replies: openrouter or gemini
CHAT_PROVIDER=openrouter
CHAT_MAX_OUTPUT_TOKENS=220
CHAT_TEMPERATURE=0.2

# Get your key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter model for chatbot replies.
# Free model examples (availability can change):
# - qwen/qwen-2.5-7b-instruct:free
# - meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_MODEL=qwen/qwen-2.5-7b-instruct:free

# Gemini fallback configuration (only needed if CHAT_PROVIDER=gemini)
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# Get your key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use for crop identification (llama-3.1-8b-instant is fast and free)
GROQ_MODEL=llama-3.1-8b-instant

# Base URL of the Java Spring Boot backend
BACKEND_BASE_URL=http://localhost:8080

# How long (seconds) to cache the crop name list
CROP_CACHE_TTL=300
