# PostgreSQL
POSTGRES_DB=solara
POSTGRES_USER=solara
POSTGRES_PASSWORD=password

# Backend security
SECURITY_JWT_SECRET=change_me_to_a_long_random_secret

# Backend mail sender credentials (Gmail SMTP by default in application.properties)
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_app_password
